{
  "display_information": {
    "name": "interchange",
    "description": "Use Interchange agents and workflows from Slack",
    "background_color": "#000000"
  },
  "features": {
    "app_home": {
      "home_tab_enabled": false,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "bot_user": {
      "display_name": "interchange",
      "always_online": true
    },
    "assistant_view": {
      "assistant_description": "Slack bridge for Interchange agents and workflows.",
      "suggested_prompts": [
        {
          "title": "Ask an agent",
          "message": "Ask the demo agent a question"
        },
        {
          "title": "Start approval workflow",
          "message": "Write a short update and ask for approval"
        }
      ]
    },
    "slash_commands": [
      {
        "command": "/demo-agent",
        "description": "Ask the Corbits demo agent from Slack",
        "usage_hint": "<your message>",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "assistant:write",
        "channels:history",
        "chat:write",
        "commands",
        "groups:history",
        "im:history",
        "im:read",
        "im:write",
        "mpim:history",
        "mpim:read",
        "mpim:write"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_mention",
        "message.channels",
        "message.groups",
        "message.im",
        "message.mpim",
        "assistant_thread_started",
        "assistant_thread_context_changed"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "is_hosted": false,
    "token_rotation_enabled": false
  }
}
